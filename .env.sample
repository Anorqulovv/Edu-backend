# Server
PORT=7001
NODE_ENV=development

# Database
DB_URL=postgresql://user:password@localhost:5432/edu_db

# JWT
JWT_SECRET=your_very_secret_jwt_key_here
ACCESS_TOKEN_KEY=your_access_token_secret
ACCESS_TOKEN_TIME=900
REFRESH_TOKEN_KEY=your_refresh_token_secret
REFRESH_TOKEN_TIME=2592000

# Telegram Bot
BOT_TOKEN=your_telegram_bot_token

# Redis (majburiy production uchun)
REDIS_HOST=localhost
REDIS_PORT=6379

# Superadmin
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=StrongPassword123!
SUPERADMIN_PHONE=+998901234567

# CORS (production'da vergul bilan ajratilib ko'rsatiladi)
ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# AI (ixtiyoriy)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
AI_TEST_GENERATION_ENABLED=false
